# Monitor Diario — configuracao de ambiente
# Copie este arquivo para .env e preencha os valores.
# .env esta no .gitignore — nunca comite suas chaves.

# ── Truflation ─────────────────────────────────────────────────────────────
# Endpoint REST (descobrir na Fase 2; pode ser free com registro).
TRUFLATION_API_KEY=

# ── Trading Economics (fallback do calendario) ─────────────────────────────
# Free tier: guest:guest funciona para poucos paises.
TE_API_KEY=guest:guest

# ── FRED (fallback do calendario US) ───────────────────────────────────────
# Ja usado em outras partes do portal; se .env existe, sobrescreve secrets.toml.
FRED_API_KEY=

# ── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
