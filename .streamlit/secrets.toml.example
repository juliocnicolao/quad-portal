# Template — copie para .streamlit/secrets.toml e preencha.
# secrets.toml esta no .gitignore; este .example eh versionado.

FRED_API_KEY = "your-fred-api-key"

# ── Turso (libSQL remoto) — Monitor Diario em producao ────────────────────
# Sem estas chaves, o app usa SQLite local (data/monitor_diario.db).
# Criar DB:  turso db create quad-monitor
# URL:       turso db show quad-monitor --url
# Token:     turso db tokens create quad-monitor
TURSO_DATABASE_URL = "libsql://quad-monitor-<org>.turso.io"
TURSO_AUTH_TOKEN   = "eyJ..."
